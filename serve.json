{
  "public": "dist",
  "rewrites": [
    { "source": "/agendamento/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/agendamento", "destination": "/index.html" },
    { "source": "/agendamento/", "destination": "/index.html" },
    { "source": "/agendamento/:path*", "destination": "/index.html" }
  ]
}
